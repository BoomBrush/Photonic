'''
Control the Brightness of LED using PWM on Raspberry Pi
http://www.electronicwings.com
'''
#import Photonic
#import RPi.GPIO as GPIO
from gpiozero import LED, PWMLED
from time import sleep

hv_pwm_pin = 13			# PWM pin connected to LED
hv_active_pin = 6

hv_pwm = PWMLED(hv_pwm_pin)
hv_active = LED(hv_active_pin)


hv_pwm.value = 0.3
print(f"Pin {hv_pwm_pin} set to 30%")

hv_active.on()
print(f"Pin {hv_active_pin} HIGH")

sleep(0.5)

print(f"Pin {hv_active_pin} LOW")
hv_active.off()
print(f"Pin {hv_pwm_pin} set to 0%")
hv_pwm.value = 0.0



